# ---------------------------------------------------------------------------
# Supabase connection — copy this file to `.env` and fill in your project values.
#
# Find these in your Supabase project dashboard:
#   Project Settings → API → Project URL, anon / publishable key, service_role
#   Project Settings → General → Reference ID
#
# In Lovable Cloud these are injected automatically. This file is only useful
# when you run the app locally or connect to your own external Supabase project.
# ---------------------------------------------------------------------------

# Client-side (exposed to the browser bundle by Vite). Safe to commit values
# only if the keys are the public publishable / anon keys.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...your_publishable_key...
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key...
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# Server-side only — read inside createServerFn handlers / server routes.
# NEVER expose the service-role key in client code or commit real values.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...your_publishable_key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role_key...
SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# ---------------------------------------------------------------------------
# M-Pesa Daraja (per business arm). Configured at runtime via the Super Admin
# Payment Config page, but you can seed defaults here for local development.
# ---------------------------------------------------------------------------
MPESA_ENV=sandbox                 # sandbox | production
MPESA_WATER_SHORTCODE=174379
MPESA_WATER_PASSKEY=
MPESA_WATER_CONSUMER_KEY=
MPESA_WATER_CONSUMER_SECRET=

MPESA_RB_SHORTCODE=174380
MPESA_RB_PASSKEY=
MPESA_RB_CONSUMER_KEY=
MPESA_RB_CONSUMER_SECRET=

# Webhook signing secret for /api/public/* endpoints (M-Pesa, GPS callbacks).
WEBHOOK_SECRET=change-me-to-a-long-random-string
